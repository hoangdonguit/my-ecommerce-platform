{
  "name": "order-db-orders-dynamic-filter-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",
    "database.hostname": "postgresql.db.svc.cluster.local",
    "database.port": "5432",
    "database.user": "postgres",
    "database.password": "<DO_NOT_COMMIT_REAL_PASSWORD>",
    "database.dbname": "order_db",
    "topic.prefix": "cdc_dynamic.order_db",
    "schema.include.list": "public",
    "table.include.list": "public.orders",
    "plugin.name": "pgoutput",
    "slot.name": "dbz_order_dynamic_filter_slot",
    "publication.name": "dbz_order_publication",
    "publication.autocreate.mode": "disabled",
    "snapshot.mode": "initial",
    "tombstones.on.delete": "false",
    "decimal.handling.mode": "string",
    "time.precision.mode": "adaptive_time_microseconds",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "transforms": "dynamicFilter,unwrap",
    "transforms.dynamicFilter.type": "io.kafkaconnect.dynamicfilter.redis.RedisDynamicFilter",
    "transforms.dynamicFilter.filter.id": "order-status-filter",
    "transforms.dynamicFilter.field.name": "status",
    "transforms.dynamicFilter.empty.list.behavior": "block_all",
    "transforms.dynamicFilter.redis.uri": "redis://redis.default.svc.cluster.local:6379",
    "transforms.dynamicFilter.redis.key": "filter:order-status",
    "transforms.dynamicFilter.redis.poll.interval.ms": "10000",
    "transforms.dynamicFilter.metrics.enabled": "true",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "true",
    "transforms.unwrap.delete.handling.mode": "rewrite",
    "transforms.unwrap.add.fields": "op,source.ts_ms,source.lsn,source.txId,table,db"
  }
}
